generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  REP
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ActivityStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum FeedbackCategory {
  FEEDBACK
  COMPLAINT
  SUGGESTION
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum GoalOwnerType {
  TEAM
  INDIVIDUAL
}

enum GoalMetricType {
  CALLS
  TEXTS
  INCOME
  ALL
}

enum GoalTimeline {
  DAILY
  WEEKLY
  MONTHLY
  ANNUAL
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  MISSED
}

enum ThreadType {
  DIRECT
  GROUP
}

enum BroadcastAudienceType {
  ALL
  GROUP
}

model User {
  id                  String              @id @default(uuid())
  fullName            String
  email               String              @unique
  phone               String?
  kingsChatUserId     String?             @unique
  kingsChatUsername   String?
  role                UserRole
  status              UserStatus          @default(ACTIVE)
  title               String?
  regionName          String?
  zoneName            String?
  pastorGroupId       String?
  pastorGroupName     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  reports             ActivityReport[]    @relation("ReportOwner")
  contacts            Contact[]
  feedbackItems       FeedbackItem[]
  assignedGoals       WeeklyGoal[]        @relation("GoalAssignee")
  createdGoals        WeeklyGoal[]        @relation("GoalCreator")
  createdScripts      WeeklyScript[]
  createdBroadcasts   Broadcast[]
  createdThreads      MessageThread[]     @relation("ThreadCreator")
  sentMessages        Message[]
  threadMemberships   ThreadParticipant[]
  managedGroups       RepGroup[]          @relation("GroupManager")
  groupMemberships    UserGroup[]
}

model RepGroup {
  id             String              @id @default(uuid())
  name           String              @unique
  description    String?
  managerId      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  manager        User?               @relation("GroupManager", fields: [managerId], references: [id], onDelete: SetNull)
  members        UserGroup[]
  scripts        WeeklyScriptGroup[]
  goals          WeeklyGoal[]
  broadcasts     Broadcast[]
}

model UserGroup {
  id        String   @id @default(uuid())
  userId    String
  groupId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     RepGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model ActivityReport {
  id            String          @id @default(uuid())
  repId         String
  contactId     String?
  activityType  String?
  incomeAmount  Int?
  contactRole   String?
  zoneName      String?
  pastorGroup   String?
  title         String
  summary       String
  actionsTaken  String
  outcome       String?
  notes         String?
  status        ActivityStatus  @default(SUBMITTED)
  verified      Boolean         @default(false)
  activityDate  DateTime
  followUpAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  rep           User            @relation("ReportOwner", fields: [repId], references: [id], onDelete: Cascade)
  contact       Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  feedbackItems FeedbackItem[]
}

model Contact {
  id           String           @id @default(uuid())
  repId        String
  fullName     String
  contactRole  String?
  zoneName     String?
  pastorGroup  String?
  company      String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  rep          User             @relation(fields: [repId], references: [id], onDelete: Cascade)
  reports      ActivityReport[]
  feedbackItems FeedbackItem[]
}

model FeedbackItem {
  id              String            @id @default(uuid())
  repId           String
  contactId       String?
  reportId        String?
  title           String
  description     String
  category        FeedbackCategory
  status          FeedbackStatus    @default(OPEN)
  resolutionNotes String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rep             User              @relation(fields: [repId], references: [id], onDelete: Cascade)
  contact         Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  report          ActivityReport?   @relation(fields: [reportId], references: [id], onDelete: SetNull)
}

model WeeklyScript {
  id          String              @id @default(uuid())
  title       String
  content     String
  weekKey     String
  isMain      Boolean             @default(false)
  isActive    Boolean             @default(false)
  createdById String
  activatedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  groups      WeeklyScriptGroup[]
}

model WeeklyScriptGroup {
  id        String       @id @default(uuid())
  scriptId  String
  groupId   String
  script    WeeklyScript @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  group     RepGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([scriptId, groupId])
}

model WeeklyGoal {
  id            String          @id @default(uuid())
  title         String
  description   String?
  weekKey       String?
  timeline      GoalTimeline    @default(WEEKLY)
  periodKey     String?
  ownerType     GoalOwnerType
  metricType    GoalMetricType
  targetValue   Int
  achievedValue Int             @default(0)
  status        GoalStatus      @default(ACTIVE)
  assigneeId    String?
  ownerGroupId  String?
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  assignee      User?           @relation("GoalAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  ownerGroup    RepGroup?       @relation(fields: [ownerGroupId], references: [id], onDelete: SetNull)
  createdBy     User            @relation("GoalCreator", fields: [createdById], references: [id], onDelete: Cascade)
}

model MessageThread {
  id             String              @id @default(uuid())
  title          String?
  type           ThreadType
  groupId        String?
  createdById    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      User                @relation("ThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants   ThreadParticipant[]
  messages       Message[]
}

model ThreadParticipant {
  id        String        @id @default(uuid())
  threadId  String
  userId    String
  createdAt DateTime      @default(now())
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id         String        @id @default(uuid())
  threadId   String
  senderId   String
  body       String
  createdAt  DateTime      @default(now())
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id            String                @id @default(uuid())
  title         String
  body          String
  audienceType  BroadcastAudienceType
  targetGroupId String?
  createdById   String
  createdAt     DateTime              @default(now())
  createdBy     User                  @relation(fields: [createdById], references: [id], onDelete: Cascade)
  targetGroup   RepGroup?             @relation(fields: [targetGroupId], references: [id], onDelete: SetNull)
}
